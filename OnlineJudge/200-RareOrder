#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
    
    vector<string> words;
    string line;
    
    // Leer palabras hasta encontrar '#'
    while (cin >> line && line != "#") {
        words.push_back(line);
    }
    
    // Grafo de 26 letras (0 = 'A', 25 = 'Z')
    vector<vector<int>> graph(26);
    vector<int> indegree(26, 0);
    vector<bool> present(26, false);
    
    // Marcar letras que aparecen en las palabras
    for (const string& w : words) {
        for (char c : w) {
            present[c - 'A'] = true;
        }
    }
    
    // Construir restricciones comparando palabras consecutivas
    for (size_t i = 0; i + 1 < words.size(); i++) {
        const string& a = words[i];
        const string& b = words[i + 1];
        
        size_t minLen = min(a.size(), b.size());
        for (size_t j = 0; j < minLen; j++) {
            if (a[j] != b[j]) {
                int u = a[j] - 'A';
                int v = b[j] - 'A';
                graph[u].push_back(v);
                break; 
            }
        }
    }
    
    // Calcular grados de entrada (indegrees)
    for (int u = 0; u < 26; u++) {
        for (int v : graph[u]) {
            indegree[v]++;
        }
    }
    
    // Kahn's algorithm para orden topologico
    queue<int> q;
    for (int i = 0; i < 26; i++) {
        if (present[i] && indegree[i] == 0) {
            q.push(i);
        }
    }
    
    string result;
    while (!q.empty()) {
        int u = q.front();
        q.pop();
        result += char(u + 'A');
        
        for (int v : graph[u]) {
            indegree[v]--;
            if (indegree[v] == 0) {
                q.push(v);
            }
        }
    }
    
    cout << result << "\n";
    
    return 0;
}