#include <bits/stdc++.h>
using namespace std;

struct DSU {
    vector<int> parent, rank;
    DSU(int n) {
        parent.resize(n);
        rank.resize(n, 0);
        for (int i = 0; i < n; i++) parent[i] = i;
    }
    int find(int x) {
        if (parent[x] != x) parent[x] = find(parent[x]);
        return parent[x];
    }
    bool unite(int x, int y) {
        int rx = find(x), ry = find(y);
        if (rx == ry) return false;
        if (rank[rx] < rank[ry]) parent[rx] = ry;
        else if (rank[rx] > rank[ry]) parent[ry] = rx;
        else { parent[ry] = rx; rank[rx]++; }
        return true;
    }
};

struct Edge {
    int u, v, w;
    bool operator<(const Edge& other) const { return w < other.w; }
};

 // Matriz de máximo para camino entre nodos 
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    int T;
    cin >> T;
    
    while (T--) {
        int N, M;
        cin >> N >> M;
        
        vector<Edge> edges(M);
        for (int i = 0; i < M; i++) {
            cin >> edges[i].u >> edges[i].v >> edges[i].w;
            edges[i].u--; edges[i].v--;
        }
        
        // Kruskal para encontrar MST
        sort(edges.begin(), edges.end());
        DSU dsu(N);
        vector<bool> inMST(M, false);
        vector<Edge> mstEdges;
        int mstCost = 0;
        
        for (int i = 0; i < M; i++) {
            if (dsu.unite(edges[i].u, edges[i].v)) {
                mstEdges.push_back(edges[i]);
                mstCost += edges[i].w;
                inMST[i] = true;
            }
        }
        
        // Construir matriz de máximo en camino para el MST
        vector<vector<int>> maxOnPath(N, vector<int>(N, 0));
        vector<vector<int>> adj(N, vector<int>(N, -1));
        
        // Llenar matriz de adyacencia del MST
        for (auto& e : mstEdges) {
            adj[e.u][e.v] = e.w;
            adj[e.v][e.u] = e.w;
        }
        
        // DFS para encontrar máximo en camino entre todos los pares
        for (int start = 0; start < N; start++) {
            vector<bool> visited(N, false);
            stack<pair<int, int>> st; // nodo, maxHastaAhora
            st.push({start, 0});
            visited[start] = true;
            
            while (!st.empty()) {
                auto [u, currentMax] = st.top();
                st.pop();
                
                for (int v = 0; v < N; v++) {
                    if (adj[u][v] != -1 && !visited[v]) {
                        visited[v] = true;
                        int newMax = max(currentMax, adj[u][v]);
                        maxOnPath[start][v] = newMax;
                        st.push({v, newMax});
                    }
                }
            }
        }
        
        // Encontrar segundo mejor MST
        int secondBest = INT_MAX;
        
        for (int i = 0; i < M; i++) {
            if (!inMST[i]) {
                // Reemplazar la arista máxima en el ciclo
                int candidate = mstCost - maxOnPath[edges[i].u][edges[i].v] + edges[i].w;
                if (candidate > mstCost && candidate < secondBest) {
                    secondBest = candidate;
                }
            }
        }
        
        // Si no se encontró, significa que hay otro MST con el mismo costo
        if (secondBest == INT_MAX) secondBest = mstCost;
        
        cout << mstCost << " " << secondBest << "\n";
    }
    
    return 0;
}